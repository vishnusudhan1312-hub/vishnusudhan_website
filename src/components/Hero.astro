---
import ApacChart from './ApacChart.astro';
---
<section class="hero" id="top">
  <div class="hero-left">
    <span class="hero-bg-mark" aria-hidden="true">VS</span>

    <div class="hero-tag-row">
      <span class="hero-section-num">§ 00 — Index</span>
      <span class="hero-coord">12.97° N · 80.08° E</span>
    </div>

    <div class="hero-tag">Business Development &middot; Digitraly</div>

    <h1 class="hero-name" data-split>
      <span class="l1">Vishnu</span>
      <span class="l2"><em>—</em>Sudhan.</span>
    </h1>

    <p class="hero-sub">Building digital transformation pipelines for APAC's regulated industries.</p>

    <div class="hero-meta">
      <div class="meta-item">
        <div class="meta-num">04<em>yrs</em></div>
        <div class="meta-label">Business dev</div>
      </div>
      <div class="meta-item">
        <div class="meta-num">05<em>mkts</em></div>
        <div class="meta-label">APAC reach</div>
      </div>
      <div class="meta-item">
        <div class="meta-num">03<em>vert</em></div>
        <div class="meta-label">Verticals</div>
      </div>
    </div>
  </div>

  <div class="hero-right">
    <span class="crosshair tl" aria-hidden="true"></span>
    <span class="crosshair tr" aria-hidden="true"></span>
    <span class="crosshair bl" aria-hidden="true"></span>
    <span class="crosshair br" aria-hidden="true"></span>

    <div class="photo-wrap">
      <img class="photo-img" src="/photo.jpg" alt="Portrait of Vishnu Sudhan" width="480" height="600" fetchpriority="high" decoding="async">
      <div class="photo-frame" aria-hidden="true"></div>
      <span class="photo-tag">Portrait · 2026</span>
      <span class="photo-meta">Vishnu Sudhan<br>Chennai, IN</span>
    </div>

    <ApacChart />
  </div>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr 360px;
    border-bottom: 1px solid var(--rule);
    position: relative;
    min-height: 580px;
  }

  .hero-left {
    padding: 36px var(--gutter) 32px var(--gutter);
    display: flex;
    flex-direction: column;
    position: relative;
    border-right: 1px solid var(--rule);
  }

  .hero-bg-mark {
    position: absolute;
    top: 8px;
    right: 12px;
    font-family: var(--font-display);
    font-size: clamp(180px, 28vw, 320px);
    line-height: 0.85;
    letter-spacing: -0.05em;
    color: var(--accent-mark);
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  .hero-tag-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
    position: relative;
    z-index: 1;
  }
  .hero-section-num {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 13px;
    color: var(--accent);
  }
  .hero-coord {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    color: var(--ink-mute);
    text-transform: uppercase;
  }

  .hero-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 28px;
    display: flex;
    align-items: center;
    gap: 12px;
    position: relative;
    z-index: 1;
  }
  .hero-tag::before {
    content: '';
    width: 24px;
    height: 1px;
    background: var(--accent);
    flex-shrink: 0;
  }

  .hero-name {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(56px, 8.5vw, 116px);
    line-height: 0.88;
    letter-spacing: -0.04em;
    color: var(--ink);
    margin: 0 0 28px;
    position: relative;
    z-index: 1;
  }
  .hero-name .l1 { display: block; }
  .hero-name .l2 {
    display: block;
    padding-left: clamp(40px, 6vw, 100px);
  }
  .hero-name .l2 em {
    color: var(--accent);
    font-style: italic;
    margin-right: 6px;
  }
  .hero-name :global(.char) {
    display: inline-block;
    opacity: 0;
    transform: translateY(28px);
    animation: char-reveal 0.85s var(--ease-out-expo) forwards;
  }

  .hero-sub {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(18px, 2.4vw, 23px);
    line-height: 1.28;
    color: var(--ink-soft);
    max-width: 460px;
    margin: 0 0 auto;
    position: relative;
    z-index: 1;
    opacity: 0;
    animation: fade-up 0.8s var(--ease-out-expo) 0.6s forwards;
  }

  .hero-meta {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    margin-top: 36px;
    padding-top: 22px;
    border-top: 1px solid var(--rule);
    position: relative;
    z-index: 1;
    opacity: 0;
    animation: fade-up 0.8s var(--ease-out-expo) 0.85s forwards;
  }
  .meta-item { padding-right: 16px; }
  .meta-num {
    font-family: var(--font-display);
    font-size: 30px;
    line-height: 1;
    color: var(--ink);
    letter-spacing: -0.03em;
    margin-bottom: 6px;
  }
  .meta-num em {
    color: var(--accent);
    font-style: italic;
    font-size: 14px;
    vertical-align: top;
    margin-left: 3px;
  }
  .meta-label {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-mute);
  }

  .hero-right {
    background: var(--bg-alt);
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .photo-wrap {
    position: relative;
    flex: 1;
    min-height: 360px;
    overflow: hidden;
  }
  .photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%) contrast(1.05) brightness(0.95);
    transition: filter 0.8s var(--ease-out), transform 6s var(--ease-out);
    transform: scale(1.04);
  }
  .photo-wrap:hover .photo-img {
    filter: grayscale(0%) contrast(1) brightness(1);
    transform: scale(1);
  }
  .photo-frame {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(180deg, rgba(14,13,12,0) 60%, rgba(14,13,12,0.7) 100%);
  }
  :global([data-theme="light"]) .photo-frame {
    background: linear-gradient(180deg, rgba(251,247,242,0) 60%, rgba(251,247,242,0.6) 100%);
  }

  .photo-tag {
    position: absolute;
    top: 14px;
    right: 14px;
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.18em;
    color: var(--accent-soft);
    text-transform: uppercase;
    z-index: 2;
  }
  .photo-meta {
    position: absolute;
    left: 14px;
    bottom: 14px;
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.15em;
    color: var(--ink-mute);
    text-transform: uppercase;
    line-height: 1.6;
    z-index: 2;
  }

  .crosshair {
    position: absolute;
    width: 10px;
    height: 10px;
    pointer-events: none;
    z-index: 3;
  }
  .crosshair::before, .crosshair::after {
    content: '';
    position: absolute;
    background: var(--accent-soft);
  }
  .crosshair::before { width: 10px; height: 1px; top: 0; left: 0; }
  .crosshair::after { width: 1px; height: 10px; top: 0; left: 0; }
  .crosshair.tl { top: 8px; left: 8px; }
  .crosshair.tr { top: 8px; right: 8px; transform: scaleX(-1); }
  .crosshair.bl { bottom: 8px; left: 8px; transform: scaleY(-1); }
  .crosshair.br { bottom: 8px; right: 8px; transform: scale(-1, -1); }

  @media (max-width: 768px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: 0;
    }
    .hero-left {
      border-right: none;
      border-bottom: 1px solid var(--rule);
      padding: 28px var(--gutter) 28px;
    }
    .hero-right { min-height: 0; }
    .hero-bg-mark { font-size: 220px; right: -8px; top: -10px; }

    .hero-name {
      font-size: clamp(48px, 13vw, 72px);
      margin-bottom: 22px;
    }
    .hero-name .l2 { padding-left: 28px; }

    .hero-sub { font-size: 19px; max-width: 100%; margin-bottom: 28px; }
    .hero-meta { margin-top: 8px; }
    .meta-num { font-size: 24px; }
    .meta-label { font-size: 8px; }

    .photo-wrap {
      min-height: 320px;
      height: 60vw;
      max-height: 420px;
    }
  }

  @media (max-width: 420px) {
    .hero-tag { font-size: 9px; }
    .hero-coord { font-size: 9px; }
    .hero-section-num { font-size: 11px; }
    .hero-name { font-size: clamp(44px, 14vw, 60px); }
  }
</style>
