---
import '../styles/tokens.css';
import '../styles/reset.css';
import '../styles/globals.css';
import '../styles/motion.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/og-image.png', Astro.site).href;

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Vishnu Sudhan',
  jobTitle: 'Business Development Manager',
  worksFor: {
    '@type': 'Organization',
    name: 'Digitraly',
    url: 'https://digitraly.com'
  },
  url: canonical,
  image: ogImage,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Chennai',
    addressRegion: 'Tamil Nadu',
    addressCountry: 'IN'
  },
  sameAs: [
    'https://linkedin.com/in/vishnu-sudhan'
  ],
  knowsAbout: [
    'Digital Transformation',
    'Aviation',
    'Fintech',
    'Healthcare',
    'Regulatory Compliance',
    'Asia-Pacific Markets'
  ]
};
---
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="color-scheme" content="dark light">
<title>{title}</title>
<meta name="description" content={description}>
<meta name="author" content="Vishnu Sudhan">
<meta name="theme-color" content="#0e0d0c" media="(prefers-color-scheme: dark)">
<meta name="theme-color" content="#fbf7f2" media="(prefers-color-scheme: light)">
<link rel="canonical" href={canonical}>

<meta property="og:title" content={title}>
<meta property="og:description" content={description}>
<meta property="og:type" content="profile">
<meta property="og:url" content={canonical}>
<meta property="og:image" content={ogImage}>
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:image:alt" content="Vishnu Sudhan — Business Development, Digitraly">
<meta property="og:locale" content="en_US">
<meta property="og:site_name" content="Vishnu Sudhan">
<meta property="profile:first_name" content="Vishnu">
<meta property="profile:last_name" content="Sudhan">

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content={title}>
<meta name="twitter:description" content={description}>
<meta name="twitter:image" content={ogImage}>
<meta name="twitter:image:alt" content="Vishnu Sudhan — Business Development, Digitraly">

<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<link rel="sitemap" href="/sitemap-index.xml">
<link rel="me" href="https://linkedin.com/in/vishnu-sudhan">

<link rel="preload" as="font" type="font/woff2" crossorigin href="/fonts/inter-variable.woff2">

<script src="/scripts/theme-init.js" is:inline></script>
<script type="application/ld+json" set:html={JSON.stringify(personJsonLd)}></script>
</head>
<body>
<a class="skip" href="#main">Skip to content</a>
<div class="scroll-progress" aria-hidden="true"></div>
<slot />
<script src="/scripts/main.js" defer is:inline></script>
</body>
</html>
